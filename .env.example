# CPlugin WebAPI .NET SDK — example environment.
# Copy to `.env` (gitignored) and export, or set the variables in your shell:
#   cp .env.example .env

# --- Credentials (required for examples and E2E) ---
# Create and manage API keys in the Toolbox (https://toolbox.cplugin.com for prod,
# https://pre.toolbox.cplugin.com for staging).
WEBAPI_CLIENT_ID=
WEBAPI_CLIENT_SECRET=

# --- Optional ---
# Trade platform GUID. Created and managed in the Toolbox. Leave empty and run
# `dotnet run --project examples/QuickStart` to list platforms accessible to
# your credentials.
WEBAPI_TRADE_PLATFORM=

# Symbol for the Streaming example (defaults to EURUSD).
WEBAPI_SYMBOL=

# Set to 1 to enable the gated staging E2E suite (`dotnet test --filter StagingE2ETests`).
WEBAPI_E2E=
